generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ScoreType {
  objective
  subjective
}

model User {
  id                 String                 @id @default(cuid())
  employeeNo         String?                @unique
  name               String
  positionName       String?
  email              String?                @unique
  mobile             String?                @unique
  wecomUserId        String?                @unique
  departmentId       String?
  sectionId          String?
  reviewGroupId      String?
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  department         Department?            @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  section            Section?               @relation("UserSection", fields: [departmentId, sectionId], references: [departmentId, id], onDelete: SetNull)
  reviewGroup        ReviewGroup?           @relation(fields: [reviewGroupId], references: [id], onDelete: SetNull)
  localAccount       LocalAccount?
  sessions           Session[]
  roleAssignments    UserRoleAssignment[]
  sectionLeadership  SectionLeaderBinding[] @relation("SectionLeaderLeader")
  groupLeadership    GroupLeaderBinding[]   @relation("GroupLeaderLeader")
  auditLogs          AuditLog[]             @relation("AuditLogActor")
  ownedGoals         Goal[]                 @relation("GoalOwner")
  reviewedKeyResults KeyResult[]            @relation("KeyResultReviewer")
  importedTemplates  ImportedGoalTemplate[] @relation("ImportedTemplateOwner")
  knowledgeAssets    KnowledgeAsset[]       @relation("KnowledgeAssetUploader")
  historicalScores   HistoricalPerformanceScore[]
  quarterParticipationExclusions QuarterParticipationExclusion[]
  rankingTieBreakDecisions RankingTieBreakDecision[]
}

model LocalAccount {
  id                String    @id @default(cuid())
  userId            String    @unique
  loginName         String    @unique
  passwordHash      String
  localLoginEnabled Boolean   @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id                     String             @id @default(cuid())
  userId                 String
  activeRoleAssignmentId String
  authMethod             String
  ip                     String?
  userAgent              String?
  expiresAt              DateTime
  lastSeenAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeRoleAssignment   UserRoleAssignment @relation("SessionActiveRole", fields: [activeRoleAssignmentId, userId], references: [id, userId], onDelete: Restrict)
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]    @relation("UserDepartment")
  sections  Section[]
  goalTemplates GoalTemplate[]
}

model Section {
  id             String                 @id @default(cuid())
  departmentId   String
  name           String
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  department     Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users          User[]                 @relation("UserSection")
  leaderBindings SectionLeaderBinding[]

  @@unique([departmentId, name])
  @@unique([departmentId, id])
}

model ReviewGroup {
  id             String               @id @default(cuid())
  name           String               @unique
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  users          User[]
  quotas         ReviewGradeQuota[]
  leaderBindings GroupLeaderBinding[]
  rankingTieBreakDecisions RankingTieBreakDecision[]
}

model ReviewGradeQuota {
  id            String      @id @default(cuid())
  reviewGroupId String
  gradeCode     String
  seatCount     Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reviewGroup   ReviewGroup @relation(fields: [reviewGroupId], references: [id], onDelete: Cascade)

  @@unique([reviewGroupId, gradeCode])
}

model RankingTieBreakDecision {
  id            String      @id @default(cuid())
  year          Int
  quarter       Int
  reviewGroupId String
  groupKey      String
  employeeId    String
  orderIndex    Int
  decidedByUserId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  reviewGroup   ReviewGroup @relation(fields: [reviewGroupId], references: [id], onDelete: Cascade)
  employee      User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([year, quarter, reviewGroupId, employeeId])
  @@unique([year, quarter, reviewGroupId, groupKey, orderIndex])
  @@index([year, quarter, reviewGroupId, groupKey])
}

model UserRoleAssignment {
  id        String    @id @default(cuid())
  userId    String
  roleCode  String
  scopeType String
  scopeId   String
  isPrimary Boolean   @default(false)
  isEnabled Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[] @relation("SessionActiveRole")

  @@unique([userId, roleCode, scopeType, scopeId])
  @@unique([id, userId])
}

model SectionLeaderBinding {
  id           String   @id @default(cuid())
  leaderUserId String
  sectionId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leader       User     @relation("SectionLeaderLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  section      Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([leaderUserId, sectionId])
}

model GroupLeaderBinding {
  id            String      @id @default(cuid())
  leaderUserId  String
  reviewGroupId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  leader        User        @relation("GroupLeaderLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  reviewGroup   ReviewGroup @relation(fields: [reviewGroupId], references: [id], onDelete: Cascade)

  @@unique([leaderUserId, reviewGroupId])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorRoleCode String?
  action        String
  entityType    String
  entityId      String?
  beforeJson    Json?
  afterJson     Json?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}

model Goal {
  id          String      @id @default(cuid())
  ownerUserId String
  year        Int
  quarter     Int
  code        String
  name        String
  description String?     @db.Text
  status      String
  totalPoints Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation("GoalOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  keyResults  KeyResult[]
  importedTemplates ImportedGoalTemplate[] @relation("ImportedTemplateGoal")

  @@unique([ownerUserId, year, quarter, code])
}

model GoalTemplate {
  id           String                 @id @default(cuid())
  departmentId String
  name         String
  description  String?                @db.Text
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  department   Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  keyResults   GoalTemplateKeyResult[]
  imports      ImportedGoalTemplate[]

  @@unique([departmentId, name])
}

model GoalTemplateKeyResult {
  id             String       @id @default(cuid())
  goalTemplateId String
  code           String
  name           String
  description    String?      @db.Text
  points         Int
  scoreType      ScoreType    @default(subjective)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  goalTemplate   GoalTemplate @relation(fields: [goalTemplateId], references: [id], onDelete: Cascade)

  @@unique([goalTemplateId, code])
}

model ImportedGoalTemplate {
  id             String       @id @default(cuid())
  goalTemplateId String
  goalId         String
  ownerUserId    String
  year           Int
  quarter        Int
  createdAt      DateTime     @default(now())
  goalTemplate   GoalTemplate @relation(fields: [goalTemplateId], references: [id], onDelete: Cascade)
  goal           Goal         @relation("ImportedTemplateGoal", fields: [goalId], references: [id], onDelete: Cascade)
  owner          User         @relation("ImportedTemplateOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([goalTemplateId, ownerUserId, year, quarter])
}

model KeyResult {
  id               String    @id @default(cuid())
  goalId           String
  code             String
  name             String
  description      String?   @db.Text
  points           Int
  scoreType        ScoreType @default(objective)
  completionState  String
  reviewScore      Float?
  reviewComment    String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  goal             Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  reviewedBy       User?     @relation("KeyResultReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  proofs           Proof[]

  @@unique([goalId, code])
}

model Proof {
  id          String    @id @default(cuid())
  keyResultId String
  fileName    String
  fileUrl     String
  fileSize    Int
  note        String?
  isKnowledge Boolean   @default(false)
  uploadedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
}

model KnowledgeAsset {
  id               String   @id @default(cuid())
  fileName         String
  fileUrl          String
  fileSize         Int
  note             String?
  uploadedByUserId String
  uploadedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  uploadedBy       User     @relation("KnowledgeAssetUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
}

model HistoricalPerformanceScore {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  quarter   Int
  score     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, quarter])
}

model QuarterParticipationExclusion {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  quarter   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, quarter])
  @@index([year, quarter])
}
